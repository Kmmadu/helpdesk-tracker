# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./helpdesk.db

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Email Configuration (optional - for email-to-ticket)
EMAIL_HOST=imap.gmail.com
EMAIL_USERNAME=support@yourcompany.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_PORT=993

# Scheduler Settings (minutes between email checks)
EMAIL_CHECK_INTERVAL=5

# Feature Flags
EMAIL_AUTO_TICKET_ENABLED=true
EMAIL_DEDUPLICATION_ENABLED=true

# Ticket Defaults
DEFAULT_TICKET_PRIORITY=Medium
DEFAULT_TICKET_CATEGORY=Network
